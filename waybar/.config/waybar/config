{
    "position": "bottom",
    "margin-bottom" : 5,
    "margin-top": -2,
    "margin-left": 0,
    "margin-right": 5,
    "height" : 30,
    "modules-left": [
      "niri/workspaces",
      "mpris",
    ],
    "modules-center": [
      "niri/window",
    ],
    "modules-right": [
    "pulseaudio",
    "bluetooth",
    "battery",
    "clock",
    ],
//    "bluetooth": {
//      "format": "\uE1A7 CHCH{status}",
//    },
    "mpris": {
      "title-len": 35,
      "format": "{player_icon} {title}",
      "format-paused": "{status_icon} {title}",
      "player-icons": {
        "default": "\uf04b",
        "mpv": "ΏθΟ╡"
      },
      "status-icons": {
        "paused": "\uf04c"
      },
    },
    "bluetooth": {
      "format": "ΎΛΦ\uf294 {status}",
      "format-off": "\uE1A9",
      "format-on": "ΎΛΦ -",
      "format-connected": "ΎΛΦ {device_alias}",
      "format-connected-battery": "ΎΛΦ {device_alias} - {device_battery_percentage}%",
      "tooltip-format-connected": "{device_enumerate}",
      "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
      "tooltip-format-enumerate-connected-battery": "{device_alias} - {device_battery_percentage}%"
    },
    "clock": {
      "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
      "format-alt": "{:%Y-%m-%d}"
    },
    "cpu": {
      "format": "  {usage}%",
      "tooltip": false
    },
    "memory": {
      "format": "{}% ΎΔΚ "
    },
    "battery": {
      "states": {
        "warning": 30,
        "critical": 15
      },
      "format": "{icon}  {capacity}%",
      "format-full": "{icon}  {capacity}%",
      "format-charging": "\uE1A3 {capacity}%",
      "format-plugged": "ΎΘο  {capacity}%",
      "format-alt": "{time} {icon}",
      "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
    },
    "network": {
      "format-wifi": "ΎΘτ  {signalStrength}%",
      "format-ethernet": "{cidr} ΎηΨ",
      "tooltip-format": "{ifname} via {gwaddr} ΎηΨ",
      "format-linked": "{ifname} (No IP) ΎηΨ",
      "format-disconnected": " έγι ",
      "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "niri/window": {
      "max-length": 65,
      "separate-outputs": true,
      "rewrite": {
        "(.*) έΑΦ Mozilla Firefox": "ΏθοΛ $1",
        "tanuj@f: (.*)": "ΎΕι $1",
      },
    },
    "pulseaudio": {
      "format": "{icon} {volume}%",
      "format-bluetooth": "{volume}% {icon} ΎΛΦ",
      "format-bluetooth-muted": "{volume}% {icon} ΎΛΦ",
      "format-muted": "{icon} {volume}%",
      "format-icons": {
        "headphone": "ΎΑξ",
        "hands-free": "ΎΨΡ",
        "headset": "\uf025",
        "phone": "ΎΓΧ",
        "portable": "ΎΓΧ",
        "car": "ΎΗ╣",
        "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
      },
      "on-click": "pavucontrol"
    },
}
